---
import { CATEGORY_LABELS, CATEGORY_SHORT, CATEGORY_COLOURS } from "@/consts";
import { formatGbp } from "@/lib/format";

/**
 * One horizontal bar split into six category segments (1.1, 1.2, 2, 3, 4, 5).
 *
 * SSR renders the initial window; client-side callers can swap the data
 * attribute and re-render via `renderCategoryBar()` in `lib/client-chart.ts`.
 * A zero-total bar falls back to a muted "no category data" line.
 */

export interface CategorySegmentInput {
  /** Category totals keyed by category code ("1.1", "2", etc.) */
  totals: Record<string, number>;
}

interface Props {
  categories: Record<string, number>;
  /** Label shown to the left of the bar (optional). */
  label?: string;
  /** Pass a URL to link the label. */
  href?: string;
  /** Show the category legend below the bar. */
  legend?: boolean;
  /** Fixed total to normalise against — for comparability between bars.
   *  If omitted, the bar fills to the sum of its own segments. */
  normaliseTo?: number;
  /** ID for client-side re-rendering. */
  barId?: string;
}

const {
  categories,
  label,
  href,
  legend = false,
  normaliseTo,
  barId,
} = Astro.props;

// Canonical category order — pins segment layout so visual comparison
// between MPs / parties stays stable.
const ORDER = ["1.1", "1.2", "2", "3", "4", "5"] as const;

function entries(): { cat: string; value: number }[] {
  return ORDER.map((cat) => ({ cat, value: categories[cat] ?? 0 }));
}

const segs = entries();
const barTotal = segs.reduce((a, s) => a + s.value, 0);
const denominator = normaliseTo && normaliseTo > 0 ? normaliseTo : barTotal;
const empty = barTotal <= 0;

// Pre-filter segments to avoid returning null from inside the JSX map,
// which Astro's compiler mis-parses as a fragment with attributes.
const visibleSegs = segs
  .map((s) => ({
    cat: s.cat,
    value: s.value,
    pct: denominator > 0 ? (s.value / denominator) * 100 : 0,
    colour: CATEGORY_COLOURS[s.cat]?.bg ?? "var(--color-ink-300)",
    title: `${CATEGORY_LABELS[s.cat] ?? s.cat} — ${formatGbp(s.value)}`,
  }))
  .filter((s) => s.pct > 0);

const legendEntries = ORDER.map((cat) => ({
  cat,
  colour: CATEGORY_COLOURS[cat]?.bg ?? "var(--color-ink-300)",
  short: CATEGORY_SHORT[cat] ?? cat,
  full: CATEGORY_LABELS[cat] ?? cat,
}));
---

<div class="wi-catbar" data-catbar={barId ?? undefined}>
  {label && (
    <div class="wi-catbar-label">
      {href ? <a href={href}>{label}</a> : label}
    </div>
  )}
  <div class="wi-catbar-track" role="img" aria-label={`Category breakdown — ${formatGbp(barTotal)} total`}>
    {empty && <div class="wi-catbar-empty">No category data in this window.</div>}
    {!empty && visibleSegs.map((s) => (
      <div
        class="wi-catbar-seg"
        style={`width: ${s.pct}%; background: ${s.colour};`}
        data-cat={s.cat}
        title={s.title}
      ></div>
    ))}
  </div>
  <div class="wi-catbar-total tabular-nums">{formatGbp(barTotal)}</div>
  {legend && (
    <ul class="wi-catbar-legend">
      {legendEntries.map((e) => (
        <li>
          <span class="wi-catbar-swatch" style={`background: ${e.colour};`} aria-hidden="true"></span>
          <span class="wi-catbar-swatch-label">
            {e.short}
            <span class="wi-catbar-swatch-full">· {e.full}</span>
          </span>
        </li>
      ))}
    </ul>
  )}
</div>

<style>
  .wi-catbar {
    display: grid;
    grid-template-columns: minmax(0, 1fr) auto;
    grid-template-areas:
      "label total"
      "track track"
      "legend legend";
    column-gap: 0.75rem;
    row-gap: 0.25rem;
    align-items: center;
    font-size: 0.85rem;
  }
  .wi-catbar-label {
    grid-area: label;
    min-width: 0;
    overflow: hidden;
    text-overflow: ellipsis;
    white-space: nowrap;
  }
  .wi-catbar-label a {
    color: inherit;
  }
  .wi-catbar-total {
    grid-area: total;
    color: var(--color-muted);
    font-size: 0.75rem;
    font-variant-numeric: tabular-nums;
  }
  .wi-catbar-track {
    grid-area: track;
    display: flex;
    height: 14px;
    background: var(--color-ink-100);
    border-radius: 2px;
    overflow: hidden;
    border: 1px solid var(--color-border);
  }
  .wi-catbar-seg {
    height: 100%;
  }
  .wi-catbar-empty {
    padding: 0 0.5rem;
    color: var(--color-muted);
    font-size: 0.75rem;
    line-height: 14px;
  }
  .wi-catbar-legend {
    grid-area: legend;
    display: flex;
    flex-wrap: wrap;
    gap: 0.25rem 0.9rem;
    list-style: none;
    padding: 0;
    margin: 0.25rem 0 0;
    color: var(--color-muted);
    font-size: 0.72rem;
  }
  .wi-catbar-legend li {
    display: inline-flex;
    align-items: center;
    gap: 0.3rem;
  }
  .wi-catbar-swatch {
    display: inline-block;
    width: 0.65rem;
    height: 0.65rem;
    border-radius: 2px;
    border: 1px solid var(--color-border);
  }
  .wi-catbar-swatch-label {
    white-space: nowrap;
  }
  .wi-catbar-swatch-full {
    color: var(--color-muted);
  }
  @media (max-width: 40rem) {
    .wi-catbar-swatch-full {
      display: none;
    }
  }
</style>
