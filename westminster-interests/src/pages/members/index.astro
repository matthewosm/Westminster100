---
import BaseLayout from "@/layouts/BaseLayout.astro";
import WindowSelector from "@/components/WindowSelector.astro";
import SummaryChart from "@/components/SummaryChart.astro";
import PartyTag from "@/components/PartyTag.astro";
import AsOfFooter from "@/components/AsOfFooter.astro";
import { formatGbp, formatNumber } from "@/lib/format";
import { DEFAULT_WINDOW } from "@/types/window";
import type { MemberIndexRow } from "@/types/member";

import membersJson from "@/data/index/members.json";

const members = membersJson as unknown as MemberIndexRow[];
const sorted = [...members].sort(
  (a, b) =>
    b.totals[DEFAULT_WINDOW].combined - a.totals[DEFAULT_WINDOW].combined,
);

const allForChartDefault = sorted
  .filter((m) => m.totals[DEFAULT_WINDOW].combined > 0)
  .map((m) => ({
    label: `${m.name} (${m.party ?? "—"})`,
    monetary: m.totals[DEFAULT_WINDOW].monetary,
    inkind: m.totals[DEFAULT_WINDOW].inkind,
    href: `/member/${m.mnis_id}`,
  }));
---

<BaseLayout
  title="Members"
  description="All MPs, sortable by declared interests across six reporting windows."
>
  <section class="py-4" data-pagefind-ignore>
    <h1 class="text-3xl mb-2">Members</h1>
    <p class="text-sm max-w-2xl" style="color: var(--color-muted);">
      Every MP who sits in this Parliament, with their registered interests.
      The chart and grid both re-compute when you change the reporting
      window.
    </p>
    <div class="mt-4">
      <WindowSelector />
    </div>
  </section>

  <section class="py-4" data-pagefind-ignore>
    <h2
      class="text-sm font-semibold uppercase tracking-wide"
      style="color: var(--color-muted);"
    >
      Top 10 — <span data-active-window-label>trailing 12 months</span>
    </h2>
    <div
      data-chart
      data-chart-json={JSON.stringify(
        Object.fromEntries(
          ["12m", "ytd", "2025", "2024", "since_election", "all_time"].map((w) => [
            w,
            sorted
              .slice()
              .filter((m) => m.totals[w as keyof typeof m.totals].combined > 0)
              .sort((a, b) => b.totals[w as keyof typeof b.totals].combined - a.totals[w as keyof typeof a.totals].combined)
              .map((m) => ({
                label: `${m.name} (${m.party ?? "—"})`,
                monetary: m.totals[w as keyof typeof m.totals].monetary,
                inkind: m.totals[w as keyof typeof m.totals].inkind,
                href: `/member/${m.mnis_id}`,
              })),
          ]),
        ),
      )}
    >
      <SummaryChart rows={allForChartDefault} limit={10} />
    </div>
  </section>

  <section class="py-2">
    <div class="wi-index-grid" data-index-grid="members">
      <!-- SSR fallback — hidden when JS mounts Grid.js. -->
      <table class="wi-ssr-fallback w-full">
        <thead>
          <tr>
            <th>Name</th>
            <th>Party</th>
            <th>Constituency</th>
            <th class="text-right">Monetary</th>
            <th class="text-right">In kind</th>
            <th class="text-right">Payments</th>
            <th class="text-right">Payers</th>
          </tr>
        </thead>
        <tbody>
          {sorted.map((m) => {
            const t = m.totals[DEFAULT_WINDOW];
            return (
              <tr>
                <td><a href={`/member/${m.mnis_id}`}>{m.name}</a></td>
                <td><PartyTag party={m.party} partySlug={m.party_slug} /></td>
                <td>{m.constituency ?? "—"}</td>
                <td class="text-right tabular-nums">{formatGbp(t.monetary)}</td>
                <td class="text-right tabular-nums">{formatGbp(t.inkind)}</td>
                <td class="text-right tabular-nums">{formatNumber(t.payment_count)}</td>
                <td class="text-right tabular-nums">{formatNumber(t.donor_count)}</td>
              </tr>
            );
          })}
        </tbody>
      </table>
      <div class="wi-grid-mount"></div>
    </div>
  </section>

  <AsOfFooter />
</BaseLayout>

<script is:inline define:vars={{ rows: members }}>
  window.__WI_MEMBERS_INDEX = rows;
</script>

<script>
  import { Grid, html } from "gridjs";
  import "gridjs/dist/theme/mermaid.min.css";
  import { DEFAULT_WINDOW, WINDOW_LABELS, isWindow } from "@/types/window";
  import type { Window } from "@/types/window";
  import type { MemberIndexRow } from "@/types/member";
  import { PARTY_SHORT } from "@/consts";

  const gbp = new Intl.NumberFormat("en-GB", {
    style: "currency",
    currency: "GBP",
    maximumFractionDigits: 0,
  });

  function escape(s: string | null | undefined): string {
    return (s ?? "")
      .replace(/&/g, "&amp;")
      .replace(/</g, "&lt;")
      .replace(/>/g, "&gt;")
      .replace(/"/g, "&quot;");
  }

  function partyTagHtml(
    party: string | null | undefined,
    slug: string | null | undefined,
  ): string {
    const tag = party
      ? (PARTY_SHORT[party] ?? party.slice(0, 3).toUpperCase())
      : "—";
    const inner = `<span class="inline-flex items-center px-1.5 py-0.5 text-xs font-semibold rounded-sm border uppercase tracking-wide" style="color: var(--color-muted); border-color: var(--color-border); background: var(--color-surface);">${escape(tag)}</span>`;
    return slug
      ? `<a href="/party/${escape(slug)}" class="no-underline" title="${escape(party ?? "")}">${inner}</a>`
      : inner;
  }

  const root = document.querySelector<HTMLElement>(
    '[data-index-grid="members"]',
  );
  if (root) {
    const data = (window as unknown as { __WI_MEMBERS_INDEX: MemberIndexRow[] })
      .__WI_MEMBERS_INDEX;
    const fallback = root.querySelector<HTMLTableElement>(".wi-ssr-fallback")!;
    const mount = root.querySelector<HTMLElement>(".wi-grid-mount")!;

    let activeWindow: Window = DEFAULT_WINDOW;

    function buildRows(win: Window) {
      return data.map((m) => [
        html(`<a href="/member/${m.mnis_id}">${escape(m.name)}</a>`),
        html(partyTagHtml(m.party, m.party_slug)),
        m.constituency ?? "—",
        gbp.format(m.totals[win].monetary),
        gbp.format(m.totals[win].inkind),
        m.totals[win].payment_count,
        m.totals[win].donor_count,
      ]);
    }

    fallback.style.display = "none";

    const grid = new Grid({
      columns: [
        { name: "Name", width: "22rem" },
        { name: "Party", width: "5rem" },
        { name: "Constituency", width: "14rem" },
        { name: "Monetary", width: "8rem", sort: { compare: cmpCurrency } },
        { name: "In kind", width: "8rem", sort: { compare: cmpCurrency } },
        { name: "Payments", width: "6rem" },
        { name: "Payers", width: "6rem" },
      ],
      data: buildRows(activeWindow),
      sort: true,
      search: true,
      resizable: true,
      pagination: { limit: 50 },
    }).render(mount);

    function cmpCurrency(a: unknown, b: unknown): number {
      const fa = parseFloat(String(a).replace(/[^0-9.-]/g, "")) || 0;
      const fb = parseFloat(String(b).replace(/[^0-9.-]/g, "")) || 0;
      return fa - fb;
    }

    document.addEventListener("window:change", (event) => {
      const detail = (event as CustomEvent).detail as { window: string };
      const next = isWindow(detail.window) ? detail.window : DEFAULT_WINDOW;
      if (next === activeWindow) return;
      activeWindow = next;
      grid.updateConfig({ data: buildRows(next) }).forceRender();
    });
  }

  // Summary-chart window swap — delegated to the shared renderer.
  const chartRoot = document.querySelector<HTMLElement>("[data-chart]");
  const chartLabel = document.querySelector<HTMLElement>("[data-active-window-label]");
  if (chartRoot) {
    const { renderSummaryChart } = await import("@/lib/client-chart");
    const chartsByWindow = JSON.parse(chartRoot.dataset.chartJson ?? "{}") as Record<
      string,
      import("@/lib/client-chart").ChartRow[]
    >;
    let chartWin: Window = DEFAULT_WINDOW;
    document.addEventListener("window:change", (event) => {
      const detail = (event as CustomEvent).detail as { window: string };
      const win: Window = isWindow(detail.window) ? detail.window : DEFAULT_WINDOW;
      if (win === chartWin) return;
      chartWin = win;
      renderSummaryChart(chartRoot, chartsByWindow[win] ?? [], { limit: 10 });
      if (chartLabel) chartLabel.textContent = WINDOW_LABELS[win];
    });
  }
</script>
