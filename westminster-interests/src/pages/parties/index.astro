---
import BaseLayout from "@/layouts/BaseLayout.astro";
import WindowSelector from "@/components/WindowSelector.astro";
import SummaryChart from "@/components/SummaryChart.astro";
import CategoryStackedBar from "@/components/CategoryStackedBar.astro";
import AsOfFooter from "@/components/AsOfFooter.astro";
import { formatGbp, formatNumber } from "@/lib/format";
import { DEFAULT_WINDOW, WINDOWS, WINDOW_LABELS } from "@/types/window";
import type { Window } from "@/types/window";
import type { PartyIndexRow } from "@/types/party";

import partiesJson from "@/data/index/parties.json";

const parties = partiesJson as unknown as PartyIndexRow[];

function avgFor(p: PartyIndexRow, w: Window) {
  const n = Math.max(p.member_count, 1);
  const t = p.totals[w];
  return {
    monetary: t.monetary / n,
    inkind: t.inkind / n,
    combined: t.combined / n,
  };
}

// Parties chart shows every party by default — the list is short
// enough that truncating to a top-10 hides meaningful signal.
function partiesForChart(win: Window) {
  return [...parties]
    .filter((p) => avgFor(p, win).combined > 0)
    .sort((a, b) => avgFor(b, win).combined - avgFor(a, win).combined)
    .map((p) => {
      const a = avgFor(p, win);
      return {
        label: p.party,
        monetary: a.monetary,
        inkind: a.inkind,
        href: `/party/${p.party_slug}`,
      };
    });
}

const defaultChart = partiesForChart(DEFAULT_WINDOW);
const chartsByWindow = Object.fromEntries(
  WINDOWS.map((w) => [w, partiesForChart(w)]),
);

const tableRows = [...parties].sort(
  (a, b) =>
    b.totals[DEFAULT_WINDOW].combined - a.totals[DEFAULT_WINDOW].combined,
);

// Per-party category breakdowns, keyed by window, so the client can
// re-render on window change without retouching the JSON.
//   partyCategorySnapshot[win][party_slug] = { "1.1": £, "1.2": £, ... }
const partyCategorySnapshot: Record<
  string,
  Record<string, Record<string, number>>
> = {};
for (const win of WINDOWS) {
  const snap: Record<string, Record<string, number>> = {};
  for (const p of parties) {
    const entry: Record<string, number> = {};
    for (const [cat, byWin] of Object.entries(p.categories ?? {})) {
      entry[cat] = byWin[win]?.combined ?? 0;
    }
    snap[p.party_slug] = entry;
  }
  partyCategorySnapshot[win] = snap;
}

// Order parties by combined total for the default window, descending,
// so the stacked-bar grid reads top-down by scale rather than alphabet.
const partiesByTotal = [...parties].sort(
  (a, b) =>
    b.totals[DEFAULT_WINDOW].combined - a.totals[DEFAULT_WINDOW].combined,
);

// Shared normaliser: the largest party's combined total. Bars become
// proportional to the biggest party rather than each filling their own
// row, so headcount + scale are both visible at a glance.
const catBarNormaliserByWindow: Record<string, number> = {};
for (const win of WINDOWS) {
  catBarNormaliserByWindow[win] = Math.max(
    1,
    ...parties.map((p) => p.totals[win].combined),
  );
}
---

<BaseLayout title="Parties" description="Party-level aggregates of MPs' declared financial interests.">
  <section class="py-4" data-pagefind-ignore>
    <h1 class="text-3xl mb-2">Parties</h1>
    <p class="text-sm max-w-2xl" style="color: var(--color-muted);">
      Party-level aggregates of registered interests. The first chart
      ranks by <em>average £ per MP</em> so headcount doesn't skew the
      picture; the grid below shows each party's category mix on a shared
      scale. The table carries both totals and averages. All three
      re-compute on window change.
    </p>
    <div class="mt-4">
      <WindowSelector />
    </div>
  </section>

  <section class="py-4" data-pagefind-ignore>
    <h2 class="text-sm font-semibold uppercase tracking-wide" style="color: var(--color-muted);">
      Parties by £ per MP — <span data-active-window-label>trailing 12 months</span>
    </h2>
    <div data-chart data-chart-json={JSON.stringify(chartsByWindow)}>
      <SummaryChart rows={defaultChart} />
    </div>
  </section>

  <section
    class="py-4"
    data-pagefind-ignore
    data-party-category-block
    data-categories-json={JSON.stringify(partyCategorySnapshot)}
    data-normalisers-json={JSON.stringify(catBarNormaliserByWindow)}
  >
    <h2 class="text-sm font-semibold uppercase tracking-wide" style="color: var(--color-muted);">
      Category mix by party — <span data-active-window-label>{WINDOW_LABELS[DEFAULT_WINDOW]}</span>
    </h2>
    <p class="text-xs mt-1 max-w-2xl" style="color: var(--color-muted);">
      Bars share a common scale — the longest bar is the party with the
      largest combined total in the selected window. Shorter bars are
      parties with smaller aggregate declarations, not narrower category
      mixes.
    </p>
    <div class="mt-3 grid gap-2">
      {partiesByTotal.map((p) => (
        <CategoryStackedBar
          categories={partyCategorySnapshot[DEFAULT_WINDOW][p.party_slug] ?? {}}
          label={p.party}
          href={`/party/${p.party_slug}`}
          normaliseTo={catBarNormaliserByWindow[DEFAULT_WINDOW]}
          barId={`party-${p.party_slug}`}
        />
      ))}
    </div>
    <div class="mt-3 flex flex-wrap gap-x-4 gap-y-1 text-xs" style="color: var(--color-muted);">
      <span class="inline-flex items-center gap-1">
        <span class="inline-block w-3 h-3 rounded-sm" style="background: #dbeafe;" aria-hidden="true"></span>Ad hoc (1.1)
      </span>
      <span class="inline-flex items-center gap-1">
        <span class="inline-block w-3 h-3 rounded-sm" style="background: #e0e7ff;" aria-hidden="true"></span>Regular (1.2)
      </span>
      <span class="inline-flex items-center gap-1">
        <span class="inline-block w-3 h-3 rounded-sm" style="background: #fee2e2;" aria-hidden="true"></span>Donations (2)
      </span>
      <span class="inline-flex items-center gap-1">
        <span class="inline-block w-3 h-3 rounded-sm" style="background: #fef3c7;" aria-hidden="true"></span>Gifts (3)
      </span>
      <span class="inline-flex items-center gap-1">
        <span class="inline-block w-3 h-3 rounded-sm" style="background: #dcfce7;" aria-hidden="true"></span>Visits (4)
      </span>
      <span class="inline-flex items-center gap-1">
        <span class="inline-block w-3 h-3 rounded-sm" style="background: #f3e8ff;" aria-hidden="true"></span>Overseas (5)
      </span>
    </div>
  </section>

  <section class="py-2">
    <div class="wi-index-grid" data-index-grid="parties">
      <table class="wi-ssr-fallback w-full">
        <thead>
          <tr>
            <th>Party</th>
            <th class="text-right">Members</th>
            <th class="text-right">Total monetary</th>
            <th class="text-right">Total in kind</th>
            <th class="text-right">Avg £/MP (cash)</th>
            <th class="text-right">Avg £/MP (in kind)</th>
            <th class="text-right">Avg £/MP (total)</th>
          </tr>
        </thead>
        <tbody>
          {tableRows.map((p) => {
            const t = p.totals[DEFAULT_WINDOW];
            const a = avgFor(p, DEFAULT_WINDOW);
            return (
              <tr>
                <td><a href={`/party/${p.party_slug}`}>{p.party}</a></td>
                <td class="text-right tabular-nums">{formatNumber(p.member_count)}</td>
                <td class="text-right tabular-nums">{formatGbp(t.monetary)}</td>
                <td class="text-right tabular-nums">{formatGbp(t.inkind)}</td>
                <td class="text-right tabular-nums">{formatGbp(a.monetary)}</td>
                <td class="text-right tabular-nums">{formatGbp(a.inkind)}</td>
                <td class="text-right tabular-nums">{formatGbp(a.combined)}</td>
              </tr>
            );
          })}
        </tbody>
      </table>
      <div class="wi-grid-mount"></div>
    </div>
  </section>

  <AsOfFooter />
</BaseLayout>

<script is:inline define:vars={{ rows: parties }}>
  window.__WI_PARTIES_INDEX = rows;
</script>

<script>
  import { Grid, html } from "gridjs";
  import "gridjs/dist/theme/mermaid.min.css";
  import { DEFAULT_WINDOW, WINDOW_LABELS, isWindow } from "@/types/window";
  import type { Window } from "@/types/window";
  import type { PartyIndexRow } from "@/types/party";
  import { renderSummaryChart, renderCategoryBar, escapeHtml } from "@/lib/client-chart";

  const gbp = new Intl.NumberFormat("en-GB", {
    style: "currency",
    currency: "GBP",
    maximumFractionDigits: 0,
  });
  const num = new Intl.NumberFormat("en-GB");

  function cmpCurrency(a: unknown, b: unknown): number {
    const fa = parseFloat(String(a).replace(/[^0-9.-]/g, "")) || 0;
    const fb = parseFloat(String(b).replace(/[^0-9.-]/g, "")) || 0;
    return fa - fb;
  }

  const root = document.querySelector<HTMLElement>('[data-index-grid="parties"]');
  if (root) {
    const data = (window as unknown as { __WI_PARTIES_INDEX: PartyIndexRow[] })
      .__WI_PARTIES_INDEX;
    const fallback = root.querySelector<HTMLTableElement>(".wi-ssr-fallback")!;
    const mount = root.querySelector<HTMLElement>(".wi-grid-mount")!;
    let activeWindow: Window = DEFAULT_WINDOW;

    function buildRows(win: Window) {
      return data.map((p) => {
        const t = p.totals[win];
        const n = Math.max(p.member_count, 1);
        return [
          html(`<a href="/party/${escapeHtml(p.party_slug)}">${escapeHtml(p.party)}</a>`),
          num.format(p.member_count),
          gbp.format(t.monetary),
          gbp.format(t.inkind),
          gbp.format(t.monetary / n),
          gbp.format(t.inkind / n),
          gbp.format(t.combined / n),
        ];
      });
    }

    fallback.style.display = "none";
    const grid = new Grid({
      columns: [
        { name: "Party", width: "16rem" },
        { name: "Members", width: "6rem" },
        { name: "Total monetary", width: "9rem", sort: { compare: cmpCurrency } },
        { name: "Total in kind", width: "9rem", sort: { compare: cmpCurrency } },
        { name: "Avg £/MP (cash)", width: "9rem", sort: { compare: cmpCurrency } },
        { name: "Avg £/MP (in kind)", width: "9rem", sort: { compare: cmpCurrency } },
        { name: "Avg £/MP (total)", width: "9rem", sort: { compare: cmpCurrency } },
      ],
      data: buildRows(activeWindow),
      sort: true,
      resizable: true,
    }).render(mount);

    document.addEventListener("window:change", (event) => {
      const detail = (event as CustomEvent).detail as { window: string };
      const next = isWindow(detail.window) ? detail.window : DEFAULT_WINDOW;
      if (next === activeWindow) return;
      activeWindow = next;
      grid.updateConfig({ data: buildRows(next) }).forceRender();
    });
  }

  const chartRoot = document.querySelector<HTMLElement>("[data-chart]");
  // Two headings now carry window labels — the averages chart and the
  // category-mix grid. Select all so both update on window change.
  const chartLabels = document.querySelectorAll<HTMLElement>("[data-active-window-label]");
  if (chartRoot) {
    const chartsByWindow = JSON.parse(chartRoot.dataset.chartJson ?? "{}") as Record<
      string,
      import("@/lib/client-chart").ChartRow[]
    >;
    let chartWin: Window = DEFAULT_WINDOW;
    document.addEventListener("window:change", (event) => {
      const detail = (event as CustomEvent).detail as { window: string };
      const win: Window = isWindow(detail.window) ? detail.window : DEFAULT_WINDOW;
      if (win === chartWin) return;
      chartWin = win;
      renderSummaryChart(chartRoot, chartsByWindow[win] ?? []);
      const text = WINDOW_LABELS[win];
      chartLabels.forEach((el) => {
        el.textContent = text;
      });
    });
  }

  // --- Per-party category stacked bars ---
  const catBlock = document.querySelector<HTMLElement>(
    "[data-party-category-block]",
  );
  if (catBlock) {
    const snapshot = JSON.parse(catBlock.dataset.categoriesJson ?? "{}") as Record<
      string,
      Record<string, Record<string, number>>
    >;
    const normalisers = JSON.parse(
      catBlock.dataset.normalisersJson ?? "{}",
    ) as Record<string, number>;
    const hosts = catBlock.querySelectorAll<HTMLElement>("[data-catbar]");
    let catWin: Window = DEFAULT_WINDOW;
    document.addEventListener("window:change", (event) => {
      const detail = (event as CustomEvent).detail as { window: string };
      const win: Window = isWindow(detail.window) ? detail.window : DEFAULT_WINDOW;
      if (win === catWin) return;
      catWin = win;
      const winSnap = snapshot[win] ?? {};
      const normaliseTo = normalisers[win] ?? 0;
      hosts.forEach((host) => {
        const id = host.dataset.catbar ?? "";
        const slug = id.startsWith("party-") ? id.slice("party-".length) : id;
        renderCategoryBar(host, winSnap[slug] ?? {}, { normaliseTo });
      });
    });
  }
</script>
